# Alpaca Paper Trading API Keys
# Get yours at: https://app.alpaca.markets/paper/dashboard/overview
# IMPORTANT: Use PAPER trading keys, not live keys.

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Optional: override Alpaca endpoints (defaults are fine for most users)
# ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# SAFETY: Keep this false. Only set to true if you understand live trading risks.
REAL_TRADING_ENABLED=false

# Risk limits (paper trading safety guardrails)
MAX_POSITION_SIZE_USD=5000
MAX_DAILY_LOSS_USD=500
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MIN_CONFIDENCE_TO_TRADE=60

# Backtest assumptions
TRANSACTION_COST_PCT=0.001
SLIPPAGE_PCT=0.0005
