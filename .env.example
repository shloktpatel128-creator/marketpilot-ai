# MarketPilot AI — environment template
# Copy to .env and fill in values. Defaults are safe (DRY_RUN only).

MODE=DRY_RUN
# REAL_TRADING_ENABLED and AI_CAN_PLACE_TRADES are hardcoded False in config.py
PAPER_TRADING_ONLY=true
MODEL_AUTO_PROMOTION=false
NEWS_AGENTS_SHADOW_MODE=true

EVALUATION_MODE=false
EVALUATION_DAYS=14

# Alpaca paper trading (optional)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Discord alerts (optional)
DISCORD_WEBHOOK_URL=

# OpenAI for agents (optional — rule-based fallback if empty)
OPENAI_API_KEY=

# Risk limits
MAX_RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_USD=500
MAX_DRAWDOWN_PCT=0.10
MAX_TRADES_PER_DAY=10
MAX_OPEN_POSITIONS=5
MIN_CONFIDENCE_TO_TRADE=60
MIN_REWARD_RISK=1.5
MAX_POSITION_SIZE_USD=5000

# Futures simulator
FUTURES_COMMISSION=2.50
FUTURES_SLIPPAGE_TICKS=1
FUTURES_MAX_DAILY_LOSS=1000
FUTURES_MAX_TRADES_DAY=20

DEFAULT_STRATEGY=vwap_momentum
DB_PATH=storage/marketpilot.db
MODEL_DIR=storage/models
